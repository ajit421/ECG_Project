# ── Backend ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@ecg-cluster.2zmnqqc.mongodb.net/?appName=ecg-cluster
JWT_SECRET=replace_with_a_long_random_secret_string
IOT_API_KEY=replace_with_a_random_api_key_for_esp32

# ── Flask ─────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace_with_flask_secret

# ── Edge / RPi ────────────────────────────────────────────────────────────
EDGE_KEY=replace_with_shared_secret_between_rpi_and_render
EDGE_DEVICE_ID=rpi-room-101
SERIAL_PORT=/dev/ttyUSB0
CLOUD_API_URL=https://<your-render-app>.onrender.com

# ── Frontend (Vite / React) ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
